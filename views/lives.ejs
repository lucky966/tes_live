<%- contentFor('pageTitle') %>
Manajemen Konten Live

<%- contentFor('body') %>
<section>
    <div class="flex justify-between items-center mb-6 border-b border-[#3f3f3f] pb-2">
        <h2 class="text-lg font-semibold text-white">Daftar Semua Tugas Live</h2>
    </div>
    <div id="liveMonitorContainer" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <p class="text-gray-500 text-sm italic">Memuat data...</p>
    </div>
</section>

<script>
    async function loadLiveMonitor() {
        const container = document.getElementById('liveMonitorContainer');
        try {
            const response = await fetch('/api/active-and-pending');
            const data = await response.json();

            if (data.schedules.length === 0) {
                container.innerHTML = '<p class="text-gray-500 text-sm">Belum ada tugas live yang dibuat. Silakan klik Buat Live Baru.</p>'; return;
            }

            container.innerHTML = '';
            data.schedules.forEach(stream => {
                const isLive = stream.status === 'live';
                const isPending = stream.status === 'pending';
                const isInactive = !isLive && !isPending;
                
                let cardClass = 'bg-[#1f1f1f] border-[#3f3f3f]';
                if (isLive) cardClass = 'bg-red-900/20 border-red-500';
                if (isInactive) cardClass = 'bg-[#151515] border-[#222] opacity-70 hover:opacity-100 transition';

                let statusIcon = '<span>⏳</span>';
                if (isLive) statusIcon = '<span class="animate-pulse h-3 w-3 bg-red-600 rounded-full"></span>';
                if (isInactive) statusIcon = '<span>⚪</span>';

                const safeTitle = stream.yt_title ? stream.yt_title.replace(/'/g, "\\'") : '';
                const safeDesc = stream.yt_desc ? stream.yt_desc.replace(/[\r\n]+/g, " ").replace(/'/g, "\\'") : '';
                
                let actionButtons = '';
                if (isLive || isPending) {
                    actionButtons = `<button onclick="stopStream(${stream.id}, '${isLive}')" class="flex-grow text-xs bg-gray-700 text-white py-1.5 rounded hover:bg-gray-600 transition">${isLive ? '⏹ STOP LIVE' : '❌ BATALKAN'}</button>`;
                } else {
                    actionButtons = `<button onclick="openScheduleModal(${stream.video_id}, ${stream.account_id || 'null'}, '${safeTitle}', '${safeDesc}', ${stream.id})" class="flex-grow text-xs bg-blue-600/30 text-blue-400 border border-blue-600/50 py-1.5 rounded hover:bg-blue-600 hover:text-white transition">✏️ EDIT & AKTIFKAN LAGI</button>`;
                }

                const div = document.createElement('div');
                div.className = `border p-4 rounded-lg flex flex-col justify-between ${cardClass}`;
                div.innerHTML = `
                    <div>
                        <div class="flex justify-between items-start mb-2">
                            <div class="flex items-center gap-2">${statusIcon}<h3 class="font-medium ${isInactive ? 'text-gray-400' : 'text-white'} line-clamp-1">${stream.title}</h3></div>
                        </div>
                        <p class="text-xs ${isInactive ? 'text-gray-600' : 'text-gray-400'} mb-1">Mulai: ${new Date(stream.scheduled_time).toLocaleString('id-ID')}</p>
                        <p class="text-xs ${isInactive ? 'text-gray-600' : 'text-gray-400'} mb-3">Selesai: ${new Date(stream.end_time).toLocaleString('id-ID')}</p>
                        ${stream.is_daily ? '<span class="bg-blue-900/50 text-blue-300 text-[10px] px-2 py-1 rounded inline-block mb-2">🔁 Harian</span>' : ''}
                        ${isInactive ? '<span class="bg-gray-800 text-gray-400 text-[10px] px-2 py-1 rounded inline-block mb-2 ml-1">TIDAK AKTIF</span>' : ''}
                    </div>
                    <div class="flex gap-2 mt-4">
                        ${actionButtons}
                        <button onclick="hapusStream(${stream.id})" class="text-xs bg-red-900/30 text-red-400 px-3 py-1.5 rounded hover:bg-red-900 hover:text-white transition" title="Hapus Permanen">🗑️</button>
                    </div>
                `;
                container.appendChild(div);
            });
        } catch (error) {}
    }

    async function stopStream(streamId, isLive) {
        if (!confirm(isLive === 'true' ? 'Hentikan siaran ini?' : 'Batalkan jadwal ini?')) return;
        await fetch(`/api/stop/${streamId}`, { method: 'POST' });
        loadLiveMonitor();
    }
    
    async function hapusStream(id) {
        if(!confirm('Hapus kartu tugas live ini secara permanen?')) return;
        try { await fetch(`/api/delete/${id}`, { method: 'POST' }); loadLiveMonitor(); } catch (error) {}
    }

    loadLiveMonitor(); setInterval(loadLiveMonitor, 5000); 
</script>