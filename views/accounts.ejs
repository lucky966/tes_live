<%- contentFor('pageTitle') %>
🔗 Akun YouTube Tertaut

<%- contentFor('body') %>
<section>
    <div class="flex justify-between items-center mb-6 border-b border-[#3f3f3f] pb-2">
        <h2 class="text-lg font-semibold text-white">Daftar Channel YouTube</h2>
        <a href="/auth/google" class="bg-blue-600 text-white px-4 py-2 text-sm font-semibold rounded hover:bg-blue-700 transition">
            + Tautkan Akun YouTube Baru
        </a>
    </div>
    
    <div id="accountsContainer" class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <p class="text-gray-500 text-sm italic">Memuat akun...</p>
    </div>
</section>

<script>
    async function loadAccounts() {
        const container = document.getElementById('accountsContainer');
        try {
            const response = await fetch('/api/accounts');
            const data = await response.json();

            if (data.accounts.length === 0) {
                container.innerHTML = '<p class="text-gray-500 text-sm col-span-3">Belum ada channel YouTube yang tertaut. Silakan klik tombol di atas.</p>'; return;
            }

            container.innerHTML = '';
            data.accounts.forEach(acc => {
                const div = document.createElement('div');
                div.className = 'bg-[#1a1a1a] border border-[#3f3f3f] p-4 rounded-lg flex items-center justify-between';
                div.innerHTML = `
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-red-600 rounded-full flex items-center justify-center text-white font-bold text-xl">Y</div>
                        <div>
                            <h3 class="font-medium text-white">${acc.channel_name}</h3>
                            <p class="text-xs text-green-400">Terkoneksi ✔️</p>
                        </div>
                    </div>
                    <button onclick="hapusAkun(${acc.id})" class="text-xs bg-[#3f3f3f] text-gray-400 px-3 py-1.5 rounded hover:bg-red-900 hover:text-white transition">Hapus</button>
                `;
                container.appendChild(div);
            });
        } catch (error) { console.error(error); }
    }
    
    async function hapusAkun(id) {
        if(!confirm('Hapus tautan akun ini?')) return;
        await fetch(`/api/accounts/delete/${id}`, { method: 'POST' });
        loadAccounts();
    }
    loadAccounts();
</script>